# Copy this file to .env and set your real values
NVIDIA_API_KEY=
STRICT_LLM_MODE=true
ALLOWED_ORIGINS=http://localhost:8005,http://127.0.0.1:8005

# Authentication
# Default behavior is local credential auth (Sign In / Create Account form on /login).
# Set AUTH_ENABLED=false only if you intentionally want public access.
AUTH_ENABLED=true

# Optional Auth0 SSO. If all three values below are set, provider switches to Auth0.
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_AUDIENCE=
AUTH0_CALLBACK_PATH=/auth/callback
AUTH0_LOGOUT_RETURN_PATH=/login

# Optional app session settings
APP_SESSION_SECRET=
SESSION_TTL_SECONDS=28800
SESSION_COOKIE_SECURE=false
